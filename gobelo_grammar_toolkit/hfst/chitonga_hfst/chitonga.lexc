! ==============================================================
! Chitonga ‚Äî Morphotactics Lexicon   chitonga.lexc
! Helsinki FST (HFST) format
! ==============================================================
! Source: chitonga_grammar.yaml  verb_system + concord_system
! Slot template: NEG(S1) PRE(S2) SM(S3) NEG(S4) TAM(S5)
!                MODAL(S6) OM(S7) ROOT(S8) EXT(S9) FV(S10) POST(S11)
!
! Compile:
!   hfst-lexc chitonga.lexc -o chitonga-morphotactics.hfst
! ==============================================================

! ‚îÄ‚îÄ MULTICHARACTER SYMBOLS ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! All abstract morpheme tags and flag diacritics must be declared
! here before any lexicon entries reference them.

Multichar_Symbols

! Part of speech
+N  +V  +ADJ  +ADV  +CONJ  +PREP  +PRON  +DEM  +INTERJ  +LOC  +AUX

! Noun classes (Meinhof numbering, all 18 + subclasses)
+NC1  +NC1a  +NC2  +NC2a  +NC2b
+NC3  +NC4   +NC5  +NC6
+NC7  +NC8
+NC9  +NC10
+NC11
+NC12 +NC13
+NC14
+NC15
+NC16 +NC17 +NC18

! Number
+SG  +PL

! Tense / Aspect / Mood  (from grammar tam: section)
! NOTE: +PST and +REM_PST share surface form "aka" ‚Äî tone distinguishes.
!       The tag is the disambiguator in the lexical representation.
+PRES       ! present habitual  (form: a,  tone: L)
+PST        ! general past      (form: aka, tone: L-L)
+REC_PST    ! recent past       (form: ali, tone: L-L)
+REM_PST    ! remote past       (form: aka, tone: H-L) ‚Äî same form as PST
+FUT_NEAR   ! near future       (form: yo)
+FUT_REM    ! remote future     (form: za)
+HAB        ! habitual          (form: la)
+PERF       ! perfect           (form: a, distinguished by FV -ide)
+SUBJ       ! subjunctive       (zero TAM + FV -e)
+IMP_SG     ! imperative SG     (form: √ò)
+IMP_PL     ! imperative PL     (form: √ò, FV: -eni)
+COND       ! conditional       (form: nga)
+POT        ! potential         (form: nga)
+PROG       ! progressive       (form: -la-/-ci-)

! Polarity
+NEG  +AFF

! Verb extensions (zones Z1-Z4, grammar derivational_extensions)
! Z1 ‚Äî valency increasing
+APPL       ! applicative       -il-/-el-
+CAUS       ! causative         -is-/-isy-/-y-
+TRANS      ! transitiviser     -ol-/-ok-
+CONT       ! contactive        -at-
! Z2 ‚Äî valency adjusting
+RECIP      ! reciprocal        -an-
+STAT       ! stative/neuter    -ik-/-ek-
! Z3 ‚Äî voice
+PASS       ! passive           -w-/-iw-/-ew-
! Z4 ‚Äî aspectual/lexical
+INTENS     ! intensive         -isy-/-esy-
+REDUP      ! reduplicative     -isisy-/-esesy-
+PERF_EXT   ! perfective ext    -ilil-/-elel-
+REV        ! reversive         -ul-/-ol-
+REPET      ! repetitive        -ulul-/-olol-
+FREQ       ! frequentative     -aul-/-auk-
+POS        ! positional        -am-

! Subject markers (SM) ‚Äî all 18 NCs + personal pronouns
! Grammar source: concord_system.concords.subject_concords
+SM1SG      ! ndi-    1st person singular
+SM2SG      ! u-/w-   2nd person singular
+SM1PL      ! tu-/tw- 1st person plural exclusive
+SM1PL_IN   ! tw-     1st person plural inclusive
+SM2PL      ! mu-/mw- 2nd person plural
+SM1        ! u-/w-   NC1 3SG human
+SM1a       ! u-/w-   NC1a kinship/proper
+SM2        ! ba-/b-  NC2 3PL human
+SM2a       ! ba-/b-  NC2a
+SM2b       ! ba-/b-  NC2b honorific
+SM3        ! u-/w-   NC3
+SM4        ! i-/y-   NC4
+SM5        ! li-/ly- NC5
+SM6        ! a-/√ò-   NC6
+SM7        ! ci-/c-  NC7
+SM8        ! zi-/zyi-/z- NC8
+SM9        ! i-/y-   NC9
+SM10       ! zi-/zy- NC10
+SM11       ! lu-/lw- NC11
+SM12       ! ka-/k-  NC12
+SM13       ! tu-/tw- NC13
+SM14       ! bu-/bw- NC14
+SM15       ! ku-/kw- NC15
+SM16       ! a-/aa-  NC16 locative
+SM17       ! ku-/kw- NC17 locative
+SM18       ! mu-/mw- NC18 locative

! Object markers (OM) ‚Äî same set
+OM1SG  +OM2SG  +OM1PL  +OM2PL
+OM1  +OM2  +OM3  +OM4  +OM5  +OM6
+OM7  +OM8  +OM9  +OM10  +OM11  +OM12
+OM13  +OM14  +OM15  +OM16  +OM17  +OM18

! Final vowel tags (grammar final_vowels section)
+FV_IND     ! -a    indicative / active
+FV_SUBJ    ! -e    subjunctive
+FV_NEG     ! -i    negative
+FV_PERF    ! -ide  perfective (perfect aspect)
+FV_IMP_SG  ! -a    imperative singular (same surface as IND)
+FV_IMP_PL  ! -eni  imperative plural
+FV_INF     ! -a    infinitive (NC15)

! Post-final clitics (grammar post_final section)
+REL        ! -yo/-o  relativiser
+Q          ! na/-nzi  question marker
+EMP        ! -ko      emphatic
+NEG_POST   ! -pe      negation reinforcement
+LOC_CLITIC ! -mo      locative clitic

! ‚îÄ‚îÄ FLAG DIACRITICS ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Purpose: enforce agreement between noun class features
! spread across multiple verb slots (SM ‚Üí OM ‚Üí demonstrative).
! Grammar ref: slot_co_occurrence validation rules.
!
! Convention:  @P.FEAT.VAL@  =  Positive (set)
!              @R.FEAT.VAL@  =  Require (must match)
!              @D.FEAT.VAL@  =  Disallow (must NOT match)
!
! NC agreement flags ‚Äî set by SM lexicon, required by OM lexicon
@P.NC.1@   @R.NC.1@   @D.NC.1@
@P.NC.2@   @R.NC.2@   @D.NC.2@
@P.NC.3@   @R.NC.3@   @D.NC.3@
@P.NC.4@   @R.NC.4@   @D.NC.4@
@P.NC.5@   @R.NC.5@   @D.NC.5@
@P.NC.6@   @R.NC.6@   @D.NC.6@
@P.NC.7@   @R.NC.7@   @D.NC.7@
@P.NC.8@   @R.NC.8@   @D.NC.8@
@P.NC.9@   @R.NC.9@   @D.NC.9@
@P.NC.10@  @R.NC.10@  @D.NC.10@
@P.NC.11@  @R.NC.11@  @D.NC.11@
@P.NC.12@  @R.NC.12@  @D.NC.12@
@P.NC.13@  @R.NC.13@  @D.NC.13@
@P.NC.14@  @R.NC.14@  @D.NC.14@
@P.NC.15@  @R.NC.15@  @D.NC.15@
@P.NC.16@  @R.NC.16@  @D.NC.16@
@P.NC.17@  @R.NC.17@  @D.NC.17@
@P.NC.18@  @R.NC.18@  @D.NC.18@

! Negation constraint flags
! Grammar rule: FV_NEG (-i) requires SLOT1 negation_pre (ta-)
! Grammar rule: SLOT1 negation_pre and SLOT4 negation_infix are mutually exclusive
@P.NEG.ON@   @R.NEG.ON@   @D.NEG.ON@

! Mood-FV agreement flags
! Grammar rule: modal.SUBJ/POT (nga-) requires FV_SUBJ (-e)
@P.MOOD.SUBJ@  @R.MOOD.SUBJ@
@P.MOOD.POT@   @R.MOOD.POT@

! Reciprocal plural constraint
! Grammar rule: RECIP requires plural subject (SM1PL, SM2PL, or NC2+)
@P.NUM.PL@  @R.NUM.PL@

! Morpheme boundary gate (for CA.1 l‚Üíd rule scoping)
@P.MORPHBOUND.ON@


! ==============================================================
! ROOT LEXICON ‚Äî entry point for the transducer
! ==============================================================

LEXICON Root
  NounPrefix ;       ! nominal paths (all NC classes)
  VerbPath ;         ! verbal paths (negation ‚Üí SM ‚Üí TAM ‚Üí OM ‚Üí root ‚Üí ext ‚Üí FV)
  ClosedClass ;      ! non-inflecting: conj, prep, interj, adv


! ==============================================================
! VERBAL PATH
! SLOT1 ‚Üí SLOT2 ‚Üí SLOT3 ‚Üí SLOT4 ‚Üí SLOT5 ‚Üí SLOT6 ‚Üí
! SLOT7 ‚Üí SLOT8 ‚Üí SLOT9 ‚Üí SLOT10 ‚Üí SLOT11
! ==============================================================

! ‚îÄ‚îÄ SLOT 1: Pre-initial negation ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: negation_pre.present forms: ["ta"]
!          negation_pre.past forms: ["tee","tii"]
!          negation_pre.subjunctive forms: ["tii"]
! Sets @P.NEG.ON@ so FinalVowel knows to produce -i not -a.

LEXICON VerbPath
  PreInitialNeg ;       ! SLOT1 ‚Äî with negation
  PreInitial ;          ! SLOT2 ‚Äî no negation (goes direct to pre-initial)

LEXICON PreInitialNeg
  ta+NEG%@P.NEG.ON@:ta PreInitial ;     ! present negative
  tee+NEG%@P.NEG.ON@:tee PreInitial ;   ! past emphatic negative
  tii+NEG%@P.NEG.ON@:tii PreInitial ;   ! subjunctive prohibition

! ‚îÄ‚îÄ SLOT 2: Pre-initial elements ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: pre_initial COND=ka, TEMP1=ni/no, TEMP2=lyo

LEXICON PreInitial
  ka+COND:ka SubjectMarker ;   ! remote future / conditional
  ni+TEMP:ni SubjectMarker ;   ! when/if conditional
  no+TEMP:no SubjectMarker ;
  lyo+TEMP:lyo SubjectMarker ; ! when (future temporal)
  SubjectMarker ;              ! zero pre-initial (most common)

! ‚îÄ‚îÄ SLOT 3: Subject markers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: concord_system.concords.subject_concords
! Forms extracted directly from grammar YAML.
! @P.NC.X@ sets the NC feature for OM agreement downstream.

LEXICON SubjectMarker
! Personal pronouns
  ndi%+SM1SG:ndi TenseMarker ;                        ! 1SG
  u%+SM2SG:u TenseMarker ;                            ! 2SG
  w%+SM2SG:w TenseMarker ;                            ! 2SG before V
  tu%+SM1PL%@P.NUM.PL@:tu TenseMarker ;               ! 1PL excl
  tw%+SM1PL_IN%@P.NUM.PL@:tw TenseMarker ;            ! 1PL incl before V
  mu%+SM2PL%@P.NUM.PL@:mu TenseMarker ;               ! 2PL
  mw%+SM2PL%@P.NUM.PL@:mw TenseMarker ;               ! 2PL before V
! NC1 ‚Äî u-/w- (3SG human)
  u%+SM1%@P.NC.1@:u TenseMarker ;
  w%+SM1%@P.NC.1@:w TenseMarker ;
! NC2 ‚Äî ba-/b- (3PL human)
  ba%+SM2%@P.NC.2@%@P.NUM.PL@:ba TenseMarker ;
  b%+SM2%@P.NC.2@%@P.NUM.PL@:b TenseMarker ;
! NC3 ‚Äî u-/w-
  u%+SM3%@P.NC.3@:u TenseMarker ;
  w%+SM3%@P.NC.3@:w TenseMarker ;
! NC4 ‚Äî i-/y-
  i%+SM4%@P.NC.4@:i TenseMarker ;
  y%+SM4%@P.NC.4@:y TenseMarker ;
! NC5 ‚Äî li-/ly-
  li%+SM5%@P.NC.5@:li TenseMarker ;
  ly%+SM5%@P.NC.5@:ly TenseMarker ;
! NC6 ‚Äî a-/√ò-
  a%+SM6%@P.NC.6@:a TenseMarker ;
! NC7 ‚Äî ci-/c-
  ci%+SM7%@P.NC.7@:ci TenseMarker ;
  c%+SM7%@P.NC.7@:c TenseMarker ;
! NC8 ‚Äî zi-/zyi-/z-
  zi%+SM8%@P.NC.8@:zi TenseMarker ;
  zyi%+SM8%@P.NC.8@:zyi TenseMarker ;
  z%+SM8%@P.NC.8@:z TenseMarker ;
! NC9 ‚Äî i-/y-
  i%+SM9%@P.NC.9@:i TenseMarker ;
  y%+SM9%@P.NC.9@:y TenseMarker ;
! NC10 ‚Äî zi-/zy-
  zi%+SM10%@P.NC.10@%@P.NUM.PL@:zi TenseMarker ;
  zy%+SM10%@P.NC.10@%@P.NUM.PL@:zy TenseMarker ;
! NC11 ‚Äî lu-/lw-
  lu%+SM11%@P.NC.11@:lu TenseMarker ;
  lw%+SM11%@P.NC.11@:lw TenseMarker ;
! NC12 ‚Äî ka-/k-
  ka%+SM12%@P.NC.12@:ka TenseMarker ;
  k%+SM12%@P.NC.12@:k TenseMarker ;
! NC13 ‚Äî tu-/tw-
  tu%+SM13%@P.NC.13@%@P.NUM.PL@:tu TenseMarker ;
  tw%+SM13%@P.NC.13@%@P.NUM.PL@:tw TenseMarker ;
! NC14 ‚Äî bu-/bw-
  bu%+SM14%@P.NC.14@:bu TenseMarker ;
  bw%+SM14%@P.NC.14@:bw TenseMarker ;
! NC15 ‚Äî ku-/kw-
  ku%+SM15%@P.NC.15@:ku TenseMarker ;
  kw%+SM15%@P.NC.15@:kw TenseMarker ;
! NC16 ‚Äî a-/aa- (locative)
  a%+SM16%@P.NC.16@:a TenseMarker ;
  aa%+SM16%@P.NC.16@:aa TenseMarker ;
! NC17 ‚Äî ku-/kw- (locative)
  ku%+SM17%@P.NC.17@:ku TenseMarker ;
  kw%+SM17%@P.NC.17@:kw TenseMarker ;
! NC18 ‚Äî mu-/mw- (locative)
  mu%+SM18%@P.NC.18@:mu TenseMarker ;
  mw%+SM18%@P.NC.18@:mw TenseMarker ;


! ‚îÄ‚îÄ SLOT 4: Negation infix (after SM, before TAM) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: negation_infix forms: ["-ta-"]
! Only appears in subordinate clause negatives.
! Co-occurrence constraint: SLOT1 negation_pre @D.NEG.ON@ blocks this.

LEXICON TenseMarker
  %@D.NEG.ON@ta%+NEG%@P.NEG.ON@:ta TenseMarkerCore ; ! infix neg (subordinate)
  TenseMarkerCore ;              ! no infix neg (main clause)

! ‚îÄ‚îÄ SLOT 5: TAM markers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar source: verbal_system_components.tam
! NOTE: PST and REM_PST share surface "aka" ‚Äî tag distinguishes them.

LEXICON TenseMarkerCore
  a%+PRES:a ObjectMarkerOrRoot ;              ! present habitual (tone L)
  aka%+PST:aka ObjectMarkerOrRoot ;           ! general past (tone L-L)
  ali%+REC_PST:ali ObjectMarkerOrRoot ;       ! recent past
  aka%+REM_PST:aka ObjectMarkerOrRoot ;       ! remote past (tone H-L ‚Äî same surface as PST)
  yo%+FUT_NEAR:yo ObjectMarkerOrRoot ;        ! near future
  za%+FUT_REM:za ObjectMarkerOrRoot ;         ! remote future
  la%+HAB:la ObjectMarkerOrRoot ;             ! habitual
  a%+PERF:a ObjectMarkerOrRoot ;              ! perfect (FV -ide disambiguates from PRES)
  ObjectMarkerOrRoot ;                        ! zero TAM (subjunctive/consecutive)

! ‚îÄ‚îÄ SLOT 6: Modal / Auxiliary ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: modal.COND forms: ["nga"], modal.POT forms: ["nga"]
! These share surface form; tag distinguishes.
! Sets @P.MOOD.SUBJ@ to enforce FV_SUBJ (-e).

LEXICON ObjectMarkerOrRoot
  nga%+COND%@P.MOOD.SUBJ@:nga ObjectMarker ; ! conditional
  nga%+POT%@P.MOOD.SUBJ@:nga ObjectMarker ;  ! potential
  la%+PROG:la ObjectMarker ;                  ! progressive infix
  ci%+PROG:ci ObjectMarker ;                  ! progressive variant
  ObjectMarker ;                              ! zero modal

! ‚îÄ‚îÄ SLOT 7: Object markers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: concord_system.concords.object_concords
! @R.NC.X@ requires that the NC was set by SM in SLOT 3.

LEXICON ObjectMarker
! Personal OM
  ndi%+OM1SG:ndi VerbRoot ;     ! 1SG object
  ku%+OM2SG:ku VerbRoot ;       ! 2SG object
  tu%+OM1PL:tu VerbRoot ;       ! 1PL object
  mu%+OM2PL:mu VerbRoot ;       ! 2PL object
! NC OM ‚Äî each requires matching NC set by SM
  mu%+OM1%@R.NC.1@:mu VerbRoot ;
  ba%+OM2%@R.NC.2@:ba VerbRoot ;
  u%+OM3%@R.NC.3@:u VerbRoot ;
  i%+OM4%@R.NC.4@:i VerbRoot ;
  li%+OM5%@R.NC.5@:li VerbRoot ;
  a%+OM6%@R.NC.6@:a VerbRoot ;
  ci%+OM7%@R.NC.7@:ci VerbRoot ;
  chi%+OM7%@R.NC.7@:chi VerbRoot ;
  zi%+OM8%@R.NC.8@:zi VerbRoot ;
  i%+OM9%@R.NC.9@:i VerbRoot ;
  zi%+OM10%@R.NC.10@:zi VerbRoot ;
  lu%+OM11%@R.NC.11@:lu VerbRoot ;
  ka%+OM12%@R.NC.12@:ka VerbRoot ;
  tu%+OM13%@R.NC.13@:tu VerbRoot ;
  bu%+OM14%@R.NC.14@:bu VerbRoot ;
  ku%+OM15%@R.NC.15@:ku VerbRoot ;
  a%+OM16%@R.NC.16@:a VerbRoot ;
  ku%+OM17%@R.NC.17@:ku VerbRoot ;
  mu%+OM18%@R.NC.18@:mu VerbRoot ;
  VerbRoot ;                     ! zero OM (most common)


! ‚îÄ‚îÄ SLOT 8: Verb root ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Populated from verbs.yaml by chitonga_transform.py
! Entries generated by the build script ‚Äî stub examples below.

LEXICON VerbRoot
! AUTO-GENERATED FROM verbs.yaml ‚Äî do not edit by hand.
! Format: stem+V:stem DerivSuffix ;  ! gloss
  bon%+V:bon DerivSuffix ;    ! see
  la%+V:la DerivSuffix ;      ! eat
  ya%+V:ya DerivSuffix ;      ! go
  lil%+V:lil DerivSuffix ;    ! cry
  bona%+V:bona DerivSuffix ;  ! see (full form ‚Äî stem=bon, FV=a; lexc resolves)
  bil%+V:bil DerivSuffix ;    ! give (from Abila)
  ban%+V:ban DerivSuffix ;    ! share (from Abana)
! ... (2000+ entries loaded from verbs.yaml at build time)


! ‚îÄ‚îÄ SLOT 9: Derivational extensions ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: derivational_extensions, zones Z1-Z4
! canonical_order: ROOT + [Z1] + [Z2] + [Z3] + [Z4] + FV
! Zone ordering enforced via continuation classes:
!   Z1 entries continue to Z2OrFV
!   Z2 entries continue to Z3OrFV
!   Z3 entries continue to FinalVowel  (PASS is always last)
!   Z4 entries continue to Z3OrFV

LEXICON DerivSuffix
! ‚îÄ‚îÄ Zone Z1: Valency-increasing ‚îÄ‚îÄ
  il%+APPL:il Z2OrFV ;          ! applicative (high-vowel stem)
  el%+APPL:el Z2OrFV ;          ! applicative (mid-vowel stem) ‚Äî VH.1
  en%+APPL:en Z2OrFV ;          ! applicative dialectal variant
  is%+CAUS:is Z2OrFV ;          ! causative (after consonant)
  isy%+CAUS:isy Z2OrFV ;        ! causative dialectal variant
  ish%+CAUS:ish Z2OrFV ;        ! causative after consonant
  esh%+CAUS:esh Z2OrFV ;        ! causative mid-vowel variant
  y%+CAUS:y Z2OrFV ;            ! causative after vowel-final stem
  ol%+TRANS:ol Z2OrFV ;         ! transitiviser
  ok%+TRANS:ok Z2OrFV ;         ! transitiviser intransitive variant
  at%+CONT:at Z2OrFV ;          ! contactive
! ‚îÄ‚îÄ Zone Z4: Aspectual/lexical (before Z2) ‚îÄ‚îÄ
  isy%+INTENS:isy Z2OrFV ;      ! intensive (NB: same surface as CAUS variant ‚Äî context disambiguates)
  ishi%+INTENS:ishi Z2OrFV ;
  esy%+INTENS:esy Z2OrFV ;
  ilil%+PERF_EXT:ilil Z2OrFV ;  ! perfective extension
  elel%+PERF_EXT:elel Z2OrFV ;
  ul%+REV:ul Z2OrFV ;           ! reversive transitive
  ol%+REV:ol Z2OrFV ;           ! reversive mid-vowel
  uk%+REV:uk Z2OrFV ;           ! reversive intransitive
  ulul%+REPET:ulul Z2OrFV ;     ! repetitive
  olol%+REPET:olol Z2OrFV ;
  aul%+FREQ:aul Z2OrFV ;        ! frequentative
  auk%+FREQ:auk Z2OrFV ;
  am%+POS:am Z2OrFV ;           ! positional
! Zero extension ‚Äî go direct to FV
  FinalVowel ;

LEXICON Z2OrFV
! ‚îÄ‚îÄ Zone Z2: Valency-adjusting ‚îÄ‚îÄ
  an%+RECIP%@R.NUM.PL@:an Z3OrFV ; ! reciprocal (requires plural SM)
  ik%+STAT:ik Z3OrFV ;          ! stative high-vowel
  ek%+STAT:ek Z3OrFV ;          ! stative mid-vowel
  Z3OrFV ;                      ! skip Z2

LEXICON Z3OrFV
! ‚îÄ‚îÄ Zone Z3: Voice ‚îÄ‚îÄ (PASS is always the final extension)
  w%+PASS:w FinalVowel ;        ! passive after vowel
  iw%+PASS:iw FinalVowel ;      ! passive after consonant
  ew%+PASS:ew FinalVowel ;      ! passive mid-vowel
  igw%+PASS:igw FinalVowel ;    ! passive after certain consonants
  FinalVowel ;                  ! skip PASS


! ‚îÄ‚îÄ SLOT 10: Final vowel ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: final_vowels section
! NEG FV (-i) requires @R.NEG.ON@ ‚Äî set only when SLOT1 has ta-.
! SUBJ FV (-e) requires @R.MOOD.SUBJ@ ‚Äî set by nga- in SLOT6.

LEXICON FinalVowel
  a%+FV_IND:a PostFinal ;                          ! indicative (default)
  e%+FV_SUBJ%@R.MOOD.SUBJ@:e PostFinal ;          ! subjunctive ‚Äî requires nga-
  i%+FV_NEG%@R.NEG.ON@:i PostFinal ;              ! negative ‚Äî requires ta-
  ide%+FV_PERF:ide PostFinal ;                     ! perfective / perfect
  eni%+FV_IMP_PL:eni PostFinal ;                   ! imperative plural

! ‚îÄ‚îÄ SLOT 11: Post-final clitics ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! Grammar: post_final section

LEXICON PostFinal
  yo%+REL:yo # ;        ! relativiser -yo
  o%+REL:o # ;          ! relativiser -o
  na%+Q:na # ;          ! question marker
  nzi%+Q:nzi # ;        ! question marker variant
  ko%+EMP:ko # ;        ! emphatic
  pe%+NEG_POST:pe # ;   ! negation reinforcement
  mo%+LOC_CLITIC:mo # ; ! locative clitic (in/at)
  # ;                    ! no post-final clitic (end of word)


! ==============================================================
! NOUN PATH ‚Äî all 18 noun classes
! ==============================================================

LEXICON NounPrefix
! ‚îÄ‚îÄ NC1 Human singular ‚îÄ‚îÄ
  mu%+NC1%+SG:mu NounRootNC1 ;
  mw%+NC1%+SG:mw NounRootNC1 ;      ! before vowel (SND.1b)
! ‚îÄ‚îÄ NC2 Human plural ‚îÄ‚îÄ
  ba%+NC2%+PL:ba NounRootNC2 ;
  b%+NC2%+PL:b NounRootNC2 ;        ! before vowel
! ‚îÄ‚îÄ NC1a/NC2a kinship / proper names (zero prefix) ‚îÄ‚îÄ
  %+NC1a%+SG: NounRootNC1a ;        ! zero prefix
! ‚îÄ‚îÄ NC3 Trees/plants singular ‚îÄ‚îÄ
  mu%+NC3%+SG:mu NounRootNC3 ;
  mw%+NC3%+SG:mw NounRootNC3 ;
! ‚îÄ‚îÄ NC4 Trees/plants plural ‚îÄ‚îÄ
  mi%+NC4%+PL:mi NounRootNC4 ;
  my%+NC4%+PL:my NounRootNC4 ;
! ‚îÄ‚îÄ NC5 Augmentative/singular ‚îÄ‚îÄ
  li%+NC5%+SG:li NounRootNC5 ;
  %+NC5%+SG: NounRootNC5 ;          ! zero prefix (many NC5 nouns)
! ‚îÄ‚îÄ NC6 Liquids/masses/plurals ‚îÄ‚îÄ
  ma%+NC6%+PL:ma NounRootNC6 ;
  m%+NC6%+PL:m NounRootNC6 ;        ! before consonant
! ‚îÄ‚îÄ NC7 Things/diminutives singular ‚îÄ‚îÄ
  ci%+NC7%+SG:ci NounRootNC7 ;
  chi%+NC7%+SG:chi NounRootNC7 ;    ! variant form
  c%+NC7%+SG:c NounRootNC7 ;        ! before vowel
! ‚îÄ‚îÄ NC8 Things/diminutives plural ‚îÄ‚îÄ
  zi%+NC8%+PL:zi NounRootNC8 ;
  zy%+NC8%+PL:zy NounRootNC8 ;      ! before vowel (SND.1a)
! ‚îÄ‚îÄ NC9 Animals/loanwords singular ‚îÄ‚îÄ
  %+NC9%+SG: NounRootNC9 ;          ! zero (before fricatives/vowels, SND.3e)
  n%+NC9%+SG:n NounRootNC9 ;        ! before alveolars
  m%+NC9%+SG:m NounRootNC9 ;        ! before bilabials (SND.3a)
  ng%+NC9%+SG:ng NounRootNC9 ;      ! before velars (SND.3c)
  ny%+NC9%+SG:ny NounRootNC9 ;      ! before palatals (SND.3d)
! ‚îÄ‚îÄ NC10 Animals/loanwords plural ‚îÄ‚îÄ
  zi%+NC10%+PL:zi NounRootNC10 ;
  zy%+NC10%+PL:zy NounRootNC10 ;
  n%+NC10%+PL:n NounRootNC10 ;      ! nasal plural
! ‚îÄ‚îÄ NC11 Long objects singular ‚îÄ‚îÄ
  lu%+NC11%+SG:lu NounRootNC11 ;
  lw%+NC11%+SG:lw NounRootNC11 ;
! ‚îÄ‚îÄ NC12 Diminutive singular ‚îÄ‚îÄ
  ka%+NC12%+SG:ka NounRootNC12 ;
  k%+NC12%+SG:k NounRootNC12 ;
! ‚îÄ‚îÄ NC13 Diminutive plural ‚îÄ‚îÄ
  tu%+NC13%+PL:tu NounRootNC13 ;
  tw%+NC13%+PL:tw NounRootNC13 ;
! ‚îÄ‚îÄ NC14 Abstract/mass ‚îÄ‚îÄ
  bu%+NC14%+SG:bu NounRootNC14 ;
  bw%+NC14%+SG:bw NounRootNC14 ;
! ‚îÄ‚îÄ NC15 Infinitives ‚îÄ‚îÄ
  ku%+NC15:ku NounRootNC15 ;
  kw%+NC15:kw NounRootNC15 ;
! ‚îÄ‚îÄ NC16 Locative definite ‚îÄ‚îÄ
  a%+NC16:a NounRootNC16 ;
  aa%+NC16:aa NounRootNC16 ;
! ‚îÄ‚îÄ NC17 Locative general ‚îÄ‚îÄ
  ku%+NC17:ku NounRootNC17 ;
  kw%+NC17:kw NounRootNC17 ;
! ‚îÄ‚îÄ NC18 Locative interior ‚îÄ‚îÄ
  mu%+NC18:mu NounRootNC18 ;
  mw%+NC18:mw NounRootNC18 ;

! ‚îÄ‚îÄ Noun root lexica ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
! These are populated from nouns.yaml by the build script.
! Each root routes to # (word boundary ‚Äî nouns don't inflect further).

LEXICON NounRootNC1
! AUTO-GENERATED FROM nouns.yaml ‚Äî stub examples
  ntu%+N:ntu # ;      ! person
  kaintu%+N:kaintu # ; ! woman
  lumi%+N:lumi # ;    ! man
  ana%+N:ana # ;      ! child (mwana after SND.1b: mu+ana‚Üímwana)
! ... (from nouns.yaml where class_singular=NC1)

LEXICON NounRootNC2
! AUTO-GENERATED ‚Äî NC2 entries (plurals of NC1)
  ntu%+N:ntu # ;      ! bantu
  kaintu%+N:kaintu # ;
! ...

LEXICON NounRootNC1a
! Kinship terms with zero prefix
  mayo%+N:mayo # ;    ! mother (informal)
  tata%+N:tata # ;    ! father
  nyina%+N:nyina # ;  ! mother (respectful)
! ...

LEXICON NounRootNC3
  ti%+N:ti # ;        ! tree/medicine (muti after mu+ti)
  nzi%+N:nzi # ;      ! wind
! ...

LEXICON NounRootNC4
! mi- + root
  ti%+N:ti # ;        ! trees (miti)
! ...

LEXICON NounRootNC5
! li- or zero + root
  nso%+N:nso # ;      ! eye (linso / inso dialectal)
  no%+N:no # ;        ! tooth (lino / ino dialectal)
  nda%+N:nda # ;      ! stomach
! ...

LEXICON NounRootNC6
! ma- + root
  anzi%+N:anzi # ;    ! water (maanzi)
  no%+N:no # ;        ! teeth (meno)
! ...

LEXICON NounRootNC7
! ci-/chi- + root
  ntu%+N:ntu # ;      ! thing (cintu)
  tonga%+N:tonga # ;  ! Tonga language (citonga)
! ...

LEXICON NounRootNC8
! zi-/zy- + root
  ntu%+N:ntu # ;      ! things (zintu)
! ...

LEXICON NounRootNC9
! nasal or zero + root
  ng%'ombe%+N:ng%'ombe # ;  ! cattle (apostrophe = prenasalised g)
  mbwa%+N:mbwa # ;    ! dog
  nkoko%+N:nkoko # ;  ! chicken
  ng%'anda%+N:ng%'anda # ;  ! house
! ...

LEXICON NounRootNC10
! plural of NC9
  ng%'ombe%+N:ng%'ombe # ;
  mbwa%+N:mbwa # ;
! ...

LEXICON NounRootNC11
  balo%+N:balo # ;    ! side (lubalo)
! ...

LEXICON NounRootNC12
! ka- + root (diminutives)
  ntu%+N:ntu # ;      ! little thing (kantu)
  na%+N:na # ;        ! little child (kana)
! ...

LEXICON NounRootNC13
! tu- + root (diminutive plural)
  ntu%+N:ntu # ;      ! little things (tuntu)
! ...

LEXICON NounRootNC14
! bu-/bw- + root (abstract)
  ntu%+N:ntu # ;      ! humanity (buntu)
  suma%+N:suma # ;    ! goodness (busuma)
! ...

LEXICON NounRootNC15
! ku-/kw- + verb root (infinitives)
! These entries are also derived from VerbRoot via infinitive path
  bon%+N:bon # ;      ! seeing (kubona)
  la%+N:la # ;        ! eating (kula)
! ...

LEXICON NounRootNC16
! a- + root (locative definite ‚Äî surface: e.g. aang'anda "at the house")
  ng%'anda%+N:ng%'anda # ;
! ...

LEXICON NounRootNC17
! ku- + root (locative general)
  ng%'anda%+N:ng%'anda # ;
! ...

LEXICON NounRootNC18
! mu- + root (locative interior)
  ng%'anda%+N:ng%'anda # ;
  nzi%+N:nzi # ;      ! inside the wind (poetic / figurative)
! ...


! ==============================================================
! CLOSED CLASS (non-inflecting)
! Grammar: closed_class.yaml
! Conjunctions, prepositions, adverbs, interjections
! These have no continuation ‚Äî they route directly to #.
! ==============================================================

LEXICON ClosedClass
! AUTO-GENERATED FROM closed_class.yaml ‚Äî stub examples
! Conjunctions
  a%+CONJ:a # ;           ! and / at / of
  aabona%+CONJ:aabona # ; ! sometimes
  naa%+CONJ:naa # ;       ! or / with (high-frequency: 3215 in corpus)
  kuti%+CONJ:kuti # ;     ! that / so that (most frequent token: 15420)
  alimwi%+CONJ:alimwi # ; ! also / and (10151 in corpus)
  kuli%+PREP:kuli # ;     ! to / at (locative)
! Demonstratives (non-inflecting surface forms stored whole)
  aabo%+DEM:aabo # ;      ! those (NC2 distal)
  abano%+DEM:abano # ;    ! these (NC2 proximal)
  ababo%+DEM:ababo # ;    ! those yonder (NC2 distal)
  aalya%+DEM:aalya # ;    ! on yonder (NC16)
! Pronouns
  aalo%+PRON:aalo # ;     ! it also (NC6)
  abalabo%+PRON:abalabo # ; ! they also (NC2/NC14)
! Adverbs
  aakale%+ADV:aakale # ;  ! later on
! ... (remaining closed class items from closed_class.yaml)
